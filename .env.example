# QP 项目安全环境变量配置示例
# 在生产环境部署前，复制此文件为 .env 并填入实际值
# 不要将 .env 文件提交到版本控制系统

# Web Session 认证令牌 (用于验证 session 签名)
# 应该是一个长的、随机的、强密钥字符串
SESSION_AUTH_TOKEN="your-strong-random-session-token-here-minimum-32-characters"

# SHA256 密码加密盐值 (用于用户密码加密)
# 应该是一个长的、随机的、唯一的字符串
# 生产环境和开发环境应使用不同的盐值
SHA256_SALT="your-sha256-salt-value-here-minimum-32-characters"

# API SHA256 盐值 (用于 API 请求签名)
# 应该是一个长的、随机的、强密钥字符串
API_SHA256_SALT="your-api-sha256-salt-here-minimum-32-characters"

# 加密认证令牌
# 用于加密通信中的认证
CRYPTO_AUTH_TOKEN="your-crypto-auth-token-here-minimum-32-characters"

# 支付渠道 IP 白名单
# 格式: 逗号分隔的 IP 地址或 CIDR 段
# 示例: 123.123.123.0/24,124.124.124.0/24
# Release 模式下必须配置
PAYMENT_CALLBACK_IPS="203.80.193.0/24,220.248.137.0/24"

# 允许的 CORS 前端域名
# 格式: 逗号分隔的完整 URL
# 开发环境示例
ALLOWED_CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080"

# 生产环境示例
# ALLOWED_CORS_ORIGINS="https://admin.example.com,https://app.example.com"

# 🔒 密钥生成建议 (仅供参考，实际应使用真实的强随机密钥)
# Linux/Mac: openssl rand -hex 32
# Go: go run -c "fmt.Println(hex.EncodeToString(make([]byte, 32)))"
# Python: python3 -c "import secrets; print(secrets.token_hex(32))"
